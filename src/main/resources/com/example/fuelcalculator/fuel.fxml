<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.fuelcalculator.FuelController"
      spacing="15" alignment="CENTER"
      style="-fx-padding: 30; -fx-background-color: #f4f4f4;">

    <Label fx:id="lblTitle"
           text="Fuel Calculator"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER">
        <Button fx:id="btnEN" text="EN" onAction="#handleEN"
                style="-fx-background-color: #FB6F90; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button fx:id="btnFR" text="FR" onAction="#handleFR"
                style="-fx-background-color: #FF69B4; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button fx:id="btnJP" text="JP" onAction="#handleJP"
                style="-fx-background-color: #DA1884; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Button fx:id="btnIR" text="IR" onAction="#handleIR"
                style="-fx-background-color: #FF0080; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>

    <Separator/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="lblDistance" text="Distance (km):"
               style="-fx-font-size: 14px;" prefWidth="220"/>
        <TextField fx:id="txtDistance" prefWidth="150"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="lblConsumption" text="Fuel Consumption (L/100 km):"
               style="-fx-font-size: 14px;" prefWidth="220"/>
        <TextField fx:id="txtConsumption" prefWidth="150"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label fx:id="lblPrice" text="Fuel Price (per liter):"
               style="-fx-font-size: 14px;" prefWidth="220"/>
        <TextField fx:id="txtPrice" prefWidth="150"/>
    </HBox>

    <Separator/>

    <Button fx:id="btnCalculate" text="Calculate Trip Cost"
            onAction="#handleCalculate"
            style="-fx-background-color: #FF647F; -fx-text-fill: #FFC0CB;
                   -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-padding: 10 20;"/>

    <Label fx:id="lblResult" text=""
           wrapText="true"
           style="-fx-font-size: 13px; -fx-text-fill: #333; -fx-padding: 10;
                  -fx-background-color: white; -fx-border-color: #FFC0CB;
                  -fx-border-radius: 5; -fx-background-radius: 5;"
           prefWidth="400" alignment="CENTER"/>

    <Label text="Anni Alanen"
           style="-fx-font-size: 14px; -fx-text-fill: black;"/>
</VBox>